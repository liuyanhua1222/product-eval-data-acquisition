# ── 隐私数据 & 运行时产物 ──────────────────────────────────────────────────

# 运行日志、采集数据（含产品信息、市场数据等隐私内容）
.cms-log/

# Cookie 会话文件（绝对不能提交，含登录凭证）
# 实际存储在 ~/.agent-browser/sessions/，此处防止误操作
sessions/
*-cookies.json
cookies-cdp-domain.json

# 截图（playwright 采集过程截图）
*.png
*.jpg
screenshot-*.png

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ── Node.js（playwright-scraper-skill 依赖）────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

# ── 编辑器 & 系统 ──────────────────────────────────────────────────────────
.DS_Store
.vscode/settings.json
.idea/
*.swp
*.swo
Thumbs.db

# ── 临时文件 ───────────────────────────────────────────────────────────────
*.tmp
*.bak
*.log
